generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ユーザープロフィール（auth.users と 1:1 で紐づく）
model UserProfile {
  id             String        @id // Supabase auth.users の UUID
  headSpeed      Float?        // ヘッドスピード (m/s)
  driverDistance Float?        // ドライバー平均飛距離 (yard)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  clubSettings   ClubSetting[]
  subscription   Subscription?
  rounds         Round[]
  shots          Shot[]

  @@map("user_profiles")
}

// 番手設定
model ClubSetting {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String
  user        UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  clubName    String      // 番手名（例: "7番アイアン"）
  loft        Float       // ロフト角 (度)
  distance    Float       // 平均飛距離 (yard)
  createdAt   DateTime    @default(now())

  @@map("club_settings")
}

// ラウンド
model Round {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String
  user       UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseName String?     // コース名（任意）
  date       DateTime    @default(now())
  isActive   Boolean     @default(true) // 現在進行中かどうか
  holes      Hole[]

  @@map("rounds")
}

// ホール
model Hole {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roundId    String   @db.Uuid
  round      Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  holeNumber Int      // 1〜18
  par        Int      @default(4)
  score      Int?     // スコア（未入力はnull）
  putts      Int?     // パット数（任意）
  pinLat     Float?   // ピン緯度
  pinLng     Float?   // ピン経度

  @@unique([roundId, holeNumber])
  @@map("holes")
}

// ショット実績
model Shot {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String
  user            UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  holeId          String?  @db.Uuid  // ホールに紐付く（任意）
  distance        Float    // AIに渡した距離（ヤード）
  recommendedClub String   // AIが推奨した番手
  usedClub        String   // 実際に使った番手
  createdAt       DateTime @default(now())

  @@map("shots")
}

// サブスクリプション
model Subscription {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String      @unique
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      Plan        @default(free)
  status    String      @default("active")
  createdAt DateTime    @default(now())

  @@map("subscriptions")
}

enum Plan {
  free
  pro
}
